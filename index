<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>蔡叔叔比薩屋 - 銷售報表</title>
    <style>
        body { font-family: "Microsoft JhengHei", sans-serif; padding: 20px; background-color: #f0f2f5; }
        .container { max-width: 800px; margin: auto; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: #333; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #dee2e6; padding: 10px; text-align: center; }
        th { background-color: #343a40; color: white; }
        .history-section { margin-top: 20px; }
    </style>
</head>
<body>

<div class="container">
    <h2>🍕 蔡叔叔比薩屋 - 即時銷售看板</h2>
    <div class="history-section">
        <table id="history-table">
            <tr><th>日期</th><th>9薄</th><th>9鬆</th><th>12薄</th><th>12鬆</th></tr>
            <tr><td colspan="5">正在讀取雲端資料...</td></tr>
        </table>
    </div>
</div>

<script>
    // --- 請填入您 Apps Script 部署後的網址 ---
    const SPREADSHEET_API = "https://script.google.com/macros/s/AKfycbw2cR6jq4dNo7vIgfu7xNnDpYI2Y3t37hNiD74oczCwRUrdcTC_6J1iX1LoSzw3y6X9sQ/exec";

    function fetchSheetData() {
        fetch(SPREADSHEET_API)
            .then(res => res.json())
            .then(data => {
                const table = document.getElementById('history-table');
                table.innerHTML = `<tr><th>日期</th><th>9薄</th><th>9鬆</th><th>12薄</th><th>12鬆</th></tr>`;
                // 反轉陣列讓最新的日期排在最上面
                data.reverse().forEach(h => {
                    table.innerHTML += `<tr><td>${h.date}</td><td>${h.s9t}</td><td>${h.s9s}</td><td>${h.s12t}</td><td>${h.s12s}</td></tr>`;
                });
            })
            .catch(err => {
                console.error("讀取失敗:", err);
                document.getElementById('history-table').innerHTML = "<tr><td colspan='5'>讀取失敗，請確認網址是否正確且已公開部署</td></tr>";
            });
    }

    // 每 10 秒自動刷新一次
    setInterval(fetchSheetData, 10000);
    fetchSheetData();
</script>

</body>
</html>
